// DC-compatible eh2_param.vh
// DC O-2018.06-SP1 analyze compiles each file independently,
// so the eh2_param_t type must be visible in the same compilation unit.
// Uses flat-packed vector instead of SV-2017 struct assignment pattern.

`ifndef EH2_PARAM_DC_VH
`define EH2_PARAM_DC_VH

`include "eh2_pdef.vh"

parameter eh2_param_t pt = 2317';

`endif // EH2_PARAM_DC_VH
