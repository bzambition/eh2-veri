# EH2 verification platform .gitignore

# Build artifacts (large, regenerable)
build/
out/
csrc/
docs/sphinx_cn/build/

# VCS / simulator artifacts
*.vcd
*.fsdb
*.daidir/
*.vdb/
simv*
ucli.key
vc_hdrs.h
.csrc.history
*.log
tr_db.log
inter.vpd
DVEfiles/

# VCS stack/crash dumps
stack.info.*
stack.info.*/
stack_*.log

# Python/pytest
__pycache__/
*.pyc
.pytest_cache/

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Symlinked external code (don't track inside this repo)
rtl/design
rtl/snapshots
vendor/google_riscv-dv

# Phase snapshots (large tar.gz, kept locally)
.scratch/snapshots/*.tar.gz
